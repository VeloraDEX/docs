{
  "name": "velora-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "mint dev --port 3001",
    "build": "mint dev --port 0",
    "check:links": "mint broken-links --check-anchors --check-snippets",
    "check:build": "mint validate",
    "check": "npm run check:links && npm run check:build"
  },
  "devDependencies": {
    "mint": "^4.2.559"
  }
}
